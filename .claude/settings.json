{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"c:\\Engine\\.claude\\save-session.js\"",
            "timeout": 20,
            "statusMessage": "Saving session memory before compact..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"c:\\Engine\\THREEJS\\update-index.js\"",
            "timeout": 15,
            "statusMessage": "Updating workspace index..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"c:\\Engine\\.claude\\validate-hook.js\"",
            "timeout": 15,
            "statusMessage": "Validating output..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"c:\\Engine\\.claude\\tsc-check.js\"",
            "timeout": 30,
            "statusMessage": "Type-checking TypeScript..."
          }
        ]
      }
    ]
  }
}
